{{ 'sub90-product-template.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sub90-product-template.js' | asset_url }}" defer="defer"></script>
<link rel="preconnect" href="https://fonts.googleapis.com" class="sub90-font-preload">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin class="sub90-font-preload">
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700;800;900&display=swap"
>

{%- liquid
  assign active_product = product
  if active_product == blank
    assign active_product = section.settings.featured_product
  endif
  assign active_variant = active_product.selected_or_first_available_variant
  assign featured_media = active_variant.featured_media | default: active_product.featured_media
  assign first_media = featured_media | default: active_product.media.first
  assign product_form_id = 'sub90-product-form-' | append: section.id
  assign variant_picker_block = section.blocks | where: 'type', 'variant_picker' | first
  assign buy_buttons_block = section.blocks | where: 'type', 'buy_buttons' | first
  assign current_price = active_variant.price | money
  assign navigation_menu = linklists[section.settings.navigation_menu]
-%}

<div class="sub90-template sub90-section color-{{ section.settings.color_scheme }}" data-sub90-main>
  {%- if active_product != blank -%}
  <div class="sub90-site-head">
    <div class="sub90-topbar">
      <div class="page-width">
        <div class="sub90-topbar__track">
          <span>{{ section.settings.announcement_1 }}</span>
          <span class="sub90-topbar__dot" aria-hidden="true">◎</span>
          <span>{{ section.settings.announcement_2 }}</span>
          <span class="sub90-topbar__dot" aria-hidden="true">◎</span>
          <span>{{ section.settings.announcement_3 }}</span>
          <span class="sub90-topbar__dot" aria-hidden="true">◎</span>
          <span>{{ section.settings.announcement_4 }}</span>
        </div>
      </div>
    </div>

    <div class="sub90-navbar">
      <div class="page-width">
        <div class="sub90-navbar__inner">
          <a class="sub90-brand" href="{{ routes.root_url }}">
            <span class="sub90-brand__main">{{ section.settings.logo_text_main }}</span>
            <span class="sub90-brand__accent">{{ section.settings.logo_text_accent }}</span>
          </a>

          <nav class="sub90-navbar__nav" aria-label="Primary">
            {%- if navigation_menu.links.size > 0 -%}
              {%- for link in navigation_menu.links -%}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            {%- else -%}
              <a href="{{ routes.root_url }}">Home</a>
              <a href="{{ routes.all_products_collection_url }}">Shop</a>
              <a href="/pages/about">About</a>
              <a href="/pages/contact">Contact</a>
            {%- endif -%}
          </nav>

          <div class="sub90-navbar__icons">
            <a href="{{ routes.search_url }}" aria-label="Search">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M20 20 16.65 16.65"></path>
              </svg>
            </a>
            <a href="{{ routes.account_url }}" aria-label="Account">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="8" r="4"></circle>
                <path d="M4 20c1.8-4 5-6 8-6s6.2 2 8 6"></path>
              </svg>
            </a>
            <a href="{{ routes.cart_url }}" aria-label="Cart" class="sub90-navbar__cart">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6 7h12l-1 12H7L6 7Z"></path>
                <path d="M9 7a3 3 0 0 1 6 0"></path>
              </svg>
              {%- if cart.item_count > 0 -%}
                <span class="sub90-navbar__count">{{ cart.item_count }}</span>
              {%- endif -%}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section id="sub90-buybox" class="sub90-hero">
    <div class="page-width">
      <div class="sub90-hero__grid">
        <div class="sub90-gallery">
          <div class="sub90-gallery__frame">
            <span class="sub90-gallery__badge sub90-gallery__badge--left">
              {{ section.settings.badge_left }}
            </span>
            <span class="sub90-gallery__badge sub90-gallery__badge--right">
              {{ section.settings.badge_right }}
            </span>
            <button
              type="button"
              class="sub90-gallery__button"
              data-sub90-lightbox-open
              aria-label="{{ section.settings.lightbox_button_label | escape }}"
            >
              {%- if first_media != blank -%}
                <img
                  class="sub90-gallery__media"
                  data-sub90-main-image
                  src="{{ first_media | image_url: width: 1600 }}"
                  alt="{{ first_media.alt | escape }}"
                  loading="eager"
                  width="{{ first_media.preview_image.width }}"
                  height="{{ first_media.preview_image.height }}"
                >
              {%- endif -%}
            </button>
            <span class="sub90-gallery__hint">{{ section.settings.gallery_hint }}</span>
          </div>

          <div class="sub90-gallery__thumbs" role="list" aria-label="{{ section.settings.thumbs_label | escape }}">
            {%- for media in active_product.media limit: 6 -%}
              <button
                type="button"
                class="sub90-gallery__thumb{% if media.id == first_media.id %} is-active{% endif %}"
                role="listitem"
                aria-label="{{ 'Show image ' | append: forloop.index }}"
                aria-pressed="{% if media.id == first_media.id %}true{% else %}false{% endif %}"
                data-sub90-thumb
                data-image-src="{{ media | image_url: width: 1600 }}"
                data-image-alt="{{ media.alt | escape }}"
              >
                {{ media | image_url: width: 240 | image_tag: loading: 'lazy', alt: media.alt }}
              </button>
            {%- endfor -%}
          </div>

          <div class="sub90-gallery__chips">
            <div class="sub90-gallery__chip">{{ section.settings.gallery_chip_1 | newline_to_br }}</div>
            <div class="sub90-gallery__chip">{{ section.settings.gallery_chip_2 | newline_to_br }}</div>
            <div class="sub90-gallery__chip">{{ section.settings.gallery_chip_3 | newline_to_br }}</div>
          </div>
        </div>

        <div class="sub90-info">
          <p class="sub90-eyebrow">{{ section.settings.eyebrow }}</p>
          <h1 class="sub90-info__title">
            {{ active_product.title }}
            <span class="sub90-info__subtitle">{{ section.settings.subtitle }}</span>
          </h1>

          <div class="sub90-info__review-row">
            <a class="sub90-info__reviews-link" href="#sub90-proof">
              <span class="sub90-stars" aria-hidden="true">★★★★★</span>
              <span class="sub90-info__review-label">{{ section.settings.review_label }}</span>
            </a>
            <span class="sub90-info__review-note">{{ section.settings.review_note }}</span>
          </div>

          <div class="sub90-info__price-row">
            <span class="sub90-info__price" data-sub90-price>{{ current_price }}</span>
            {%- if section.settings.compare_price_text != blank -%}
              <span class="sub90-info__compare">{{ section.settings.compare_price_text }}</span>
            {%- endif -%}
          </div>
          <p class="sub90-info__ship-note">{{ section.settings.shipping_note }}</p>

          <ul class="sub90-info__benefits">
            <li><span>✓</span>{{ section.settings.benefit_1 }}</li>
            <li><span>✓</span>{{ section.settings.benefit_2 }}</li>
            <li><span>✓</span>{{ section.settings.benefit_3 }}</li>
          </ul>

          {%- if variant_picker_block -%}
            <div class="sub90-main-variants">
              {% render 'product-variant-picker',
                product: active_product,
                block: variant_picker_block,
                product_form_id: product_form_id
              %}
            </div>
          {%- endif -%}

          {%- assign setup_blocks = section.blocks | where: 'type', 'setup' -%}
          {%- if setup_blocks.size > 0 -%}
            <div class="sub90-setup-picker">
              <div class="sub90-setup-picker__head">
                <p class="sub90-setup-picker__title">{{ section.settings.setup_heading }}</p>
                <p class="sub90-setup-picker__note">{{ section.settings.setup_note }}</p>
              </div>

              {%- for block in setup_blocks -%}
                <div class="sub90-setup-card{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                  {%- if block.settings.badge != blank -%}
                    <span class="sub90-setup-card__badge">{{ block.settings.badge }}</span>
                  {%- endif -%}
                  <span class="sub90-setup-card__radio" aria-hidden="true"></span>
                  <div>
                    <p class="sub90-setup-card__name">{{ block.settings.title }}</p>
                    <p class="sub90-setup-card__desc">{{ block.settings.text }}</p>
                    {%- if block.settings.save_text != blank -%}
                      <span class="sub90-setup-card__save">{{ block.settings.save_text }}</span>
                    {%- endif -%}
                  </div>
                  <div class="sub90-setup-card__price-col">
                    <div class="sub90-setup-card__price">{{ block.settings.price }}</div>
                    {%- if block.settings.compare_price != blank -%}
                      <span class="sub90-setup-card__compare">{{ block.settings.compare_price }}</span>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- assign addon_blocks = section.blocks | where: 'type', 'addon' -%}
          {%- if addon_blocks.size > 0 -%}
            <div class="sub90-addons">
              <p class="sub90-addons__title">{{ section.settings.addon_heading }}</p>
              <p class="sub90-addons__subtitle">{{ section.settings.addon_subtitle }}</p>

              {%- for block in addon_blocks -%}
                <div class="sub90-addon-card" {{ block.shopify_attributes }}>
                  <span class="sub90-addon-card__box" aria-hidden="true"></span>
                  <div>
                    <p class="sub90-addon-card__name">{{ block.settings.title }}</p>
                    <p class="sub90-addon-card__desc">{{ block.settings.text }}</p>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if buy_buttons_block -%}
            <div class="sub90-main-form">
              {% render 'buy-buttons',
                block: buy_buttons_block,
                product: active_product,
                product_form_id: product_form_id,
                section_id: section.id,
                show_pickup_availability: false
              %}
            </div>
          {%- endif -%}

          <div class="sub90-info__countdown">
            <span>{{ section.settings.countdown_prefix }}</span>
            <strong>{{ section.settings.countdown_time }}</strong>
            <span>{{ section.settings.countdown_suffix }}</span>
          </div>

          <div class="sub90-info__signature">
            <span class="sub90-info__seal">{{ section.settings.signature_badge }}</span>
            <p class="sub90-info__signature-copy">{{ section.settings.signature_copy }}</p>
          </div>

          <div class="sub90-info__service-grid">
            <div class="sub90-info__service-card">
              <p class="sub90-info__service-title">{{ section.settings.service_title_1 }}</p>
              <p class="sub90-info__service-body">{{ section.settings.service_body_1 }}</p>
            </div>
            <div class="sub90-info__service-card">
              <p class="sub90-info__service-title">{{ section.settings.service_title_2 }}</p>
              <p class="sub90-info__service-body">{{ section.settings.service_body_2 }}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="sub90-lightbox" data-sub90-lightbox>
    <div class="sub90-lightbox__dialog" role="dialog" aria-modal="true" aria-label="{{ section.settings.lightbox_button_label | escape }}">
      <button type="button" class="sub90-lightbox__close" data-sub90-lightbox-close aria-label="Close">×</button>
      <img class="sub90-lightbox__image" data-sub90-lightbox-image alt="" width="1600" height="1600">
    </div>
  </div>

  <div class="sub90-mobile-bar">
    <div class="page-width">
      <div class="sub90-mobile-bar__inner">
        <div>
          <p class="sub90-mobile-bar__label">{{ section.settings.sticky_label }}</p>
          <p class="sub90-mobile-bar__title">{{ section.settings.sticky_title }}</p>
          <p class="sub90-mobile-bar__price" data-sub90-sticky-price>{{ current_price }}</p>
        </div>
        <a class="sub90-mobile-bar__cta" href="#sub90-buybox">{{ section.settings.sticky_button }}</a>
      </div>
    </div>
  </div>
  {%- else -%}
    <section class="sub90-hero">
      <div class="page-width">
        <p class="sub90-info__ship-note">Choose a product in this section to render the SUB90 product template.</p>
      </div>
    </section>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "SUB90 Product Main",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2" },
    { "type": "product", "id": "featured_product", "label": "Featured product" },
    { "type": "link_list", "id": "navigation_menu", "label": "Navigation menu" },
    { "type": "text", "id": "announcement_1", "label": "Announcement 1", "default": "WE ❤️ LEG DAY" },
    { "type": "text", "id": "announcement_2", "label": "Announcement 2", "default": "FREE US GROUND SHIPPING" },
    { "type": "text", "id": "announcement_3", "label": "Announcement 3", "default": "MADE BY ATHLETES IN FRISCO, TX 🇺🇸" },
    { "type": "text", "id": "announcement_4", "label": "Announcement 4", "default": "30-DAY \"YOU CHICKENED OUT\" RETURNS" },
    { "type": "text", "id": "logo_text_main", "label": "Logo text main", "default": "SUB" },
    { "type": "text", "id": "logo_text_accent", "label": "Logo text accent", "default": "90" },
    { "type": "text", "id": "badge_left", "label": "Left badge", "default": "Bestseller" },
    { "type": "text", "id": "badge_right", "label": "Right badge", "default": "Made in USA" },
    { "type": "text", "id": "gallery_hint", "label": "Gallery hint", "default": "Hover to zoom. Click to expand." },
    { "type": "text", "id": "thumbs_label", "label": "Thumbnail list label", "default": "Product images" },
    { "type": "text", "id": "gallery_chip_1", "label": "Gallery chip 1", "default": "Impact-Resistant PETG" },
    { "type": "text", "id": "gallery_chip_2", "label": "Gallery chip 2", "default": "Indoor + Outdoor" },
    { "type": "text", "id": "gallery_chip_3", "label": "Gallery chip 3", "default": "Patent Pending" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Built for Hyrox-style training" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Wall-Mounted. Competition Height." },
    { "type": "text", "id": "review_label", "label": "Review label", "default": "4 verified reviews" },
    { "type": "text", "id": "review_note", "label": "Review note", "default": "Loved by garage-gym and Hyrox athletes" },
    { "type": "text", "id": "compare_price_text", "label": "Compare price text" },
    { "type": "text", "id": "shipping_note", "label": "Shipping note", "default": "USD. Free US shipping, calculated at checkout. Ships from Frisco, TX." },
    { "type": "text", "id": "benefit_1", "label": "Benefit 1", "default": "Free US shipping" },
    { "type": "text", "id": "benefit_2", "label": "Benefit 2", "default": "30-day returns" },
    { "type": "text", "id": "benefit_3", "label": "Benefit 3", "default": "Made in the USA" },
    { "type": "text", "id": "setup_heading", "label": "Setup heading", "default": "Choose your setup" },
    { "type": "text", "id": "setup_note", "label": "Setup note", "default": "Most pick the HYROX Home Kit" },
    { "type": "text", "id": "addon_heading", "label": "Add-on heading", "default": "Add the essentials?" },
    { "type": "text", "id": "addon_subtitle", "label": "Add-on subtitle", "default": "Two quick adds most athletes grab." },
    { "type": "text", "id": "countdown_prefix", "label": "Countdown prefix", "default": "Order within" },
    { "type": "text", "id": "countdown_time", "label": "Countdown time", "default": "13:21:43" },
    { "type": "text", "id": "countdown_suffix", "label": "Countdown suffix", "default": "to ship today" },
    { "type": "text", "id": "signature_badge", "label": "Signature badge", "default": "S90" },
    { "type": "textarea", "id": "signature_copy", "label": "Signature copy", "default": "Packed and shipped by the small SUB90 crew in Frisco, TX. A real person answers info@sub90fitness.com within 24 hours." },
    { "type": "text", "id": "service_title_1", "label": "Service title 1", "default": "Free Ground Shipping" },
    { "type": "textarea", "id": "service_body_1", "label": "Service body 1", "default": "On all US orders. Shipping policy." },
    { "type": "text", "id": "service_title_2", "label": "Service title 2", "default": "30-Day Returns" },
    { "type": "textarea", "id": "service_body_2", "label": "Service body 2", "default": "Our \"you chickened out\" guarantee. Return policy." },
    { "type": "text", "id": "lightbox_button_label", "label": "Lightbox button label", "default": "Open image in full screen" },
    { "type": "text", "id": "sticky_label", "label": "Sticky bar label", "default": "SUB90 Target" },
    { "type": "text", "id": "sticky_title", "label": "Sticky bar title", "default": "SUB90 Target" },
    { "type": "text", "id": "sticky_button", "label": "Sticky bar button", "default": "Add to Cart" }
  ],
  "blocks": [
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "picker_type",
          "label": "Picker type",
          "default": "button",
          "options": [
            { "value": "dropdown", "label": "Dropdown" },
            { "value": "button", "label": "Buttons" }
          ]
        },
        {
          "type": "select",
          "id": "swatch_shape",
          "label": "Swatch shape",
          "default": "circle",
          "options": [
            { "value": "circle", "label": "Circle" },
            { "value": "square", "label": "Square" },
            { "value": "none", "label": "None" }
          ]
        }
      ]
    },
    {
      "type": "buy_buttons",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout", "default": false },
        { "type": "checkbox", "id": "show_gift_card_recipient", "label": "Show gift card recipient", "default": false }
      ]
    },
    {
      "type": "setup",
      "name": "Setup card",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge" },
        { "type": "text", "id": "title", "label": "Title", "default": "Just the Target" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "One wall, one station. The classic." },
        { "type": "text", "id": "price", "label": "Price", "default": "$34.99" },
        { "type": "text", "id": "compare_price", "label": "Compare price" },
        { "type": "text", "id": "save_text", "label": "Save text" }
      ]
    },
    {
      "type": "addon",
      "name": "Add-on card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "SUB90 height marking kit +$12" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Vinyl markers for the 9ft and 10ft lines. SUB90 only." }
      ]
    }
  ],
  "presets": [
    {
      "name": "SUB90 Product Main",
      "blocks": [
        { "type": "variant_picker" },
        { "type": "setup" },
        { "type": "setup" },
        { "type": "setup" },
        { "type": "addon" },
        { "type": "addon" },
        { "type": "buy_buttons" }
      ]
    }
  ]
}
{% endschema %}
