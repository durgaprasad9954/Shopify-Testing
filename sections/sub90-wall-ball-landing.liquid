    addUrl:(window.Shopify && Shopify.routes && Shopify.routes.root ? Shopify.routes.root : '/')+'cart/add.js',
    cartStateUrl:(window.Shopify && Shopify.routes && Shopify.routes.root ? Shopify.routes.root : '/')+'cart.js',
    addonVariantIds:{
      height:'52517704401207',
      chalk:'52517704499511'
    },
    bundleItemVariantIds:{
      hyrox:['52517705941303','52517705974071'],
      complete:['52517706006839','52517706039607','52517704499511']
    }
  };

  /* mobile nav */
  var menuBtn=$('#menuBtn'), mobileNav=$('#mobileNav');
  if(menuBtn){ menuBtn.addEventListener('click',function(){ var open=mobileNav.classList.toggle('hidden')===false; menuBtn.setAttribute('aria-expanded',open?'true':'false'); }); }

  /* data */
  var variants=[
    {name:'Black / White', a:'#0A0A0A', b:'#FFFFFF', img:'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-main.jpg?v=1782277347', variantId:'{{ variant_black_white }}'},
    {name:'Black / Orange',a:'#0A0A0A', b:'#FF5A1F', img:'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-black-orange.png?v=1782277357', variantId:'{{ variant_black_orange }}'},
    {name:'White / Black', a:'#FFFFFF', b:'#0A0A0A', img:'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-white-black.jpg?v=1782277370', variantId:'{{ variant_white_black }}'},
    {name:'White / Blue',  a:'#FFFFFF', b:'#2563EB', img:'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-white-blue.png?v=1782277376', variantId:'{{ variant_white_blue }}'}
  ];
  var gallery=[
    'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-main.jpg?v=1782277347',
    'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-front.jpg?v=1782277402',
    'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-crew.jpg?v=1782277444',
    'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-athlete.png?v=1782277455',
    'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-white-black.jpg?v=1782277370',
    'https://cdn.shopify.com/s/files/1/0996/9683/6919/files/sub90-white-blue.png?v=1782277376'
  ];
  var mainImage=$('#mainImage'), stickyThumb=$('#stickyThumb'), current=0, selectedVariantIndex=0;

  /* thumbnails */
  var tWrap=$('#thumbs');
  gallery.forEach(function(src,i){
    var btn=document.createElement('button');
    btn.setAttribute('role','listitem');
    btn.className='thumb shrink-0 w-16 h-16 sm:w-20 sm:h-20 rounded-lg overflow-hidden border-2 focus-ring '+(i===0?'border-orangeInk':'border-neutral-200');
    btn.setAttribute('aria-label','Show image '+(i+1)); btn.setAttribute('aria-pressed', i===0?'true':'false');
    btn.innerHTML='<img src="'+src.replace('width=1100','width=300')+'" alt="" class="w-full h-full object-cover">';
    btn.addEventListener('click',function(){ setImage(i); });
    tWrap.appendChild(btn);
  });
  function setImage(i){
    current=i; mainImage.src=gallery[i];
    $$('.thumb').forEach(function(t,idx){ t.classList.toggle('border-orangeInk',idx===i); t.classList.toggle('border-neutral-200',idx!==i); t.setAttribute('aria-pressed',idx===i?'true':'false'); });
  }

  /* variants with keyboard (radiogroup) */
  var vWrap=$('#variants');
  variants.forEach(function(v,i){
    var b=document.createElement('button');
    b.className='variant-swatch relative w-12 h-12 rounded-full border-2 focus-ring overflow-hidden '+(i===0?'border-orangeInk':'border-neutral-300');
    b.setAttribute('role','radio'); b.setAttribute('aria-checked',i===0?'true':'false'); b.setAttribute('aria-label',v.name);
    b.tabIndex = i===0?0:-1;
    b.style.background='linear-gradient(135deg, '+v.a+' 0 50%, '+v.b+' 50% 100%)';
    b.addEventListener('click',function(){ selectVariant(i); });
    b.addEventListener('keydown',function(e){
      var n=null;
      if(e.key==='ArrowRight'||e.key==='ArrowDown') n=(i+1)%variants.length;
      else if(e.key==='ArrowLeft'||e.key==='ArrowUp') n=(i-1+variants.length)%variants.length;
      if(n!==null){ e.preventDefault(); selectVariant(n); $$('.variant-swatch')[n].focus(); }
    });
    vWrap.appendChild(b);
  });
  function selectVariant(i){
    selectedVariantIndex=i;
    $$('.variant-swatch').forEach(function(s,idx){
      var on=idx===i;
      s.classList.toggle('border-orangeInk',on); s.classList.toggle('border-neutral-300',!on);
      s.setAttribute('aria-checked',on?'true':'false'); s.tabIndex=on?0:-1;
    });
    $('#variantName').textContent=variants[i].name;
    mainImage.src=variants[i].img; stickyThumb.src=variants[i].img;
    // sync gallery current to the matching variant image if present
    var gi=gallery.indexOf(variants[i].img); if(gi>=0){ current=gi; setImage(gi); } else { current=0; }
  }

  /* bundles + add-ons: live subtotal */
  var bundlePrice=34.99, bundleCompare=0, price=34.99;
  function fmt(n){return '$'+n.toFixed(2)}
  function addonsTotal(){
    var t=0; $$('.addon-check').forEach(function(c){ if(c.checked) t+=parseFloat(c.dataset.price); }); return t;
  }
  function recalc(){
    var add=addonsTotal();
    price=bundlePrice+add;
    var compareBase=(bundleCompare||bundlePrice)+add;
    $('#priceTag').textContent=fmt(price);
    $('#ctaPrice').textContent=fmt(price);
    $('#stickyPrice').textContent=fmt(price);
    var cmp=$('#comparePrice'), sb=$('#saveBadge');
    var saved=compareBase-price;
    if(saved>0.005){
      cmp.textContent=fmt(compareBase); cmp.classList.remove('hidden');
      sb.textContent='Save '+fmt(saved); sb.classList.remove('hidden');
    } else { cmp.classList.add('hidden'); sb.classList.add('hidden'); }
    var n=$$('.addon-check').filter(function(c){return c.checked}).length;
    var note=$('#addonNote'); if(note) note.textContent = n? (n+(n>1?' add-ons':' add-on')+' selected') : '';
  }
  function selectBundle(opt){
    $$('.bundle-opt').forEach(function(o){
      var on=o===opt;
      o.classList.toggle('border-action',on); o.classList.toggle('bg-action/5',on);
      o.classList.toggle('border-neutral-200',!on); o.setAttribute('aria-checked',on?'true':'false');
      o.tabIndex=on?0:-1;
      var dot=o.querySelector('.bundle-dot'); var inner=dot&&dot.firstElementChild;
      if(dot){ dot.classList.toggle('border-action',on); dot.classList.toggle('border-neutral-300',!on); }
      if(inner){ inner.classList.toggle('bg-action',on); inner.classList.toggle('bg-transparent',!on); }
    });
    bundlePrice=parseFloat(opt.dataset.price);
    bundleCompare=opt.dataset.compare?parseFloat(opt.dataset.compare):0;
    recalc();
  }
  var bundleOpts=$$('.bundle-opt');
  bundleOpts.forEach(function(opt,i){
    opt.tabIndex = i===0?0:-1;
    opt.addEventListener('click',function(){ selectBundle(opt); });
    opt.addEventListener('keydown',function(e){
      var n=null;
      if(e.key==='ArrowDown'||e.key==='ArrowRight') n=(i+1)%bundleOpts.length;
      else if(e.key==='ArrowUp'||e.key==='ArrowLeft') n=(i-1+bundleOpts.length)%bundleOpts.length;
      if(n!==null){ e.preventDefault(); selectBundle(bundleOpts[n]); bundleOpts[n].focus(); }
    });
  });
  $$('.addon-check').forEach(function(c){
    c.addEventListener('change',function(){
      var lbl=c.closest('.addon-opt');
      if(lbl){ lbl.classList.toggle('border-action',c.checked); lbl.classList.toggle('bg-action/5',c.checked); lbl.classList.toggle('border-neutral-200',!c.checked); }
      recalc();
    });
  });
  recalc();

  /* add to cart + live region */
  var cartCount=$('#cartCount'), toast=$('#toast'), live=$('#liveRegion');
  function setToast(message){
    toast.textContent=message;
    toast.style.opacity='1';
    toast.style.transform='translateY(0)';
    setTimeout(function(){ toast.style.opacity='0'; toast.style.transform='translateY(-8px)'; },1800);
  }
  function selectedBundleKey(){
    var selected=bundleOpts.filter(function(opt){ return opt.getAttribute('aria-checked')==='true'; })[0];
    return selected ? selected.dataset.bundle : 'single';
  }
  function pushItem(counts, id, quantity){
    counts[id]=(counts[id]||0)+quantity;
  }
  function buildCartItems(){
    var counts={};
    var variantId=variants[selectedVariantIndex].variantId;
    var bundleKey=selectedBundleKey();
    pushItem(counts, variantId, 1);
    if(shopifyData.bundleItemVariantIds[bundleKey]){
      shopifyData.bundleItemVariantIds[bundleKey].forEach(function(id){ pushItem(counts, id, 1); });
    }
    $$('.addon-check').forEach(function(c){
      if(c.checked && shopifyData.addonVariantIds[c.dataset.addon]){
        pushItem(counts, shopifyData.addonVariantIds[c.dataset.addon], 1);
      }
    });
    return Object.keys(counts).map(function(id){
      return { id:Number(id), quantity:counts[id] };
    });
  }
  function buildCartPermalink(items){
    return (window.Shopify && Shopify.routes && Shopify.routes.root ? Shopify.routes.root : '/') + 'cart/' + items.map(function(item){
      return String(item.id) + ':' + String(item.quantity);
    }).join(',');
  }
  function submitCartForm(items){
    var form=document.createElement('form');
    form.method='post';
    form.action=(window.Shopify && Shopify.routes && Shopify.routes.root ? Shopify.routes.root : '/')+'cart/add';
    form.acceptCharset='UTF-8';
    form.enctype='multipart/form-data';
    form.noValidate=true;

    function appendHidden(name, value){
      var input=document.createElement('input');
      input.type='hidden';
      input.name=name;
      input.value=String(value);
      form.appendChild(input);
    }

    appendHidden('form_type', 'product');
    appendHidden('utf8', '✓');

    if(items.length===1){
      appendHidden('id', items[0].id);
      appendHidden('quantity', items[0].quantity);
      appendHidden('product-id', '{{ fallback_product_id }}');
      appendHidden('section-id', 'sub90-home-landing');
    } else {
      items.forEach(function(item,index){
        appendHidden('items['+index+'][id]', item.id);
        appendHidden('items['+index+'][quantity]', item.quantity);
      });
    }
    document.body.appendChild(form);
    form.submit();
  }
  async function refreshCartCount(){
    try{
      var response=await fetch(shopifyData.cartStateUrl,{ headers:{ Accept:'application/json' } });
      if(!response.ok) return;
      var cart=await response.json();
      cartCount.textContent=String(cart.item_count || 0);
    }catch(error){}
  }
  async function addToCart(){
    live.textContent='Taking you to your cart.';
    window.location.href='/products/sub90-wall-ball-target?sub90_autocart=1';
  }
  $('#addToCart').addEventListener('click',addToCart);
  $$('.js-add').forEach(function(b){ b.addEventListener('click',addToCart); });
  $$('.js-scrolltop').forEach(function(a){ a.addEventListener('click',function(e){ e.preventDefault(); window.scrollTo({top:0,behavior:'smooth'}); }); });
  refreshCartCount();

  /* "Choose this setup" cards -> select matching bundle + scroll to buy box */
  $$('.js-pick').forEach(function(b){
    b.addEventListener('click',function(){
      var key=b.dataset.goto;
      var target=bundleOpts.filter(function(o){return o.dataset.bundle===key})[0];
      if(target){ selectBundle(target); }
      var box=$('#buybox'); if(box) box.scrollIntoView({behavior:'smooth',block:'start'});
    });
  });

  /* sticky bar */
  var sticky=$('#stickyBar'), cta=$('#addToCart');
  if('IntersectionObserver' in window){
    new IntersectionObserver(function(es){ es.forEach(function(en){ if(en.isIntersecting){ sticky.style.transform='translateY(100%)'; } else if(en.boundingClientRect.top<0){ sticky.style.transform='translateY(0)'; } }); },{threshold:0}).observe(cta);
  }

  /* scroll reveal */
  if('IntersectionObserver' in window){
    var ro=new IntersectionObserver(function(es){ es.forEach(function(en){ if(en.isIntersecting){ en.target.classList.add('in'); ro.unobserve(en.target); } }); },{threshold:.12});
    $$('.reveal').forEach(function(el){ ro.observe(el); });
  } else { $$('.reveal').forEach(function(el){ el.classList.add('in'); }); }

  /* countdown to 2pm CST cutoff */
  var cd=$('#countdown');
  function tick(){
    var now=new Date();
    var cutoff=new Date(Date.UTC(now.getUTCFullYear(),now.getUTCMonth(),now.getUTCDate(),20,0,0));
    if(now.getTime()>cutoff.getTime()) cutoff.setUTCDate(cutoff.getUTCDate()+1);
    var d=Math.max(0,cutoff.getTime()-now.getTime());
    var h=Math.floor(d/3.6e6),m=Math.floor(d%3.6e6/6e4),s=Math.floor(d%6e4/1e3);
    cd.textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  }
  tick(); setInterval(tick,1000);

  /* ---- accessible dialogs (lightbox + video) ---- */
  var lastFocus=null;
  function trap(modal,e){
    var f=$$('button, [href], img[tabindex], [tabindex]:not([tabindex="-1"])',modal).filter(function(el){return el.offsetParent!==null});
    if(!f.length) return; var first=f[0], last=f[f.length-1];
    if(e.key==='Tab'){
      if(e.shiftKey && document.activeElement===first){ e.preventDefault(); last.focus(); }
      else if(!e.shiftKey && document.activeElement===last){ e.preventDefault(); first.focus(); }
    }
  }
  function openModal(modal){
    lastFocus=document.activeElement; modal.classList.remove('hidden');
    var btn=$('[data-close]',modal); if(btn) btn.focus();
    document.body.style.overflow='hidden';
    modal._key=function(e){ if(e.key==='Escape'){ closeModal(modal); } trap(modal,e); };
    document.addEventListener('keydown',modal._key);
  }
  function closeModal(modal){
    modal.classList.add('hidden'); document.body.style.overflow='';
    document.removeEventListener('keydown',modal._key);
    if(modal.id==='videoModal'){ /* stop video by clearing holder if iframe was injected */ }
    if(lastFocus) lastFocus.focus();
  }
  $$('[data-close]').forEach(function(el){ el.addEventListener('click',function(){ closeModal(el.closest('[role=dialog]')); }); });

  /* lightbox */
  var lightbox=$('#lightbox'), lbImage=$('#lbImage');
  function showLb(i){ current=(i+gallery.length)%gallery.length; lbImage.src=gallery[current]; lbImage.alt='SUB90 wall ball target, image '+(current+1); }
  $('#lightboxBtn').addEventListener('click',function(){ showLb(current); openModal(lightbox); });
  $('#lbPrev').addEventListener('click',function(){ showLb(current-1); });
  $('#lbNext').addEventListener('click',function(){ showLb(current+1); });
  document.addEventListener('keydown',function(e){
    if(lightbox.classList.contains('hidden')) return;
    if(e.key==='ArrowRight') showLb(current+1);
    if(e.key==='ArrowLeft') showLb(current-1);
  });

  /* video modal */
  var videoModal=$('#videoModal');
  $('#videoBtn').addEventListener('click',function(){
    /* WIRE: inject your real embed, e.g.:
       $('#videoHolder').innerHTML='<iframe class="w-full h-full" src="https://www.youtube.com/embed/XXXX?autoplay=1" title="SUB90 demo" allow="autoplay; fullscreen" allowfullscreen></iframe>'; */
    openModal(videoModal);
  });
})();

