<script>
  tailwind.config = {
    theme: { extend: {
      colors: {
        ink:'#0A0A0A', coal:'#141414', action:'#FF5A1F', actionDark:'#E8480F',
        orangeInk:'#B23A0F', paper:'#F7F5F2'
      },
      fontFamily: { display:['Anton','sans-serif'], sans:['Inter','sans-serif'] },
      boxShadow: { cta:'0 12px 34px -10px rgba(255,90,31,0.6)', soft:'0 8px 30px -12px rgba(0,0,0,0.25)' },
    } },
  };
</script>
{%- liquid
  assign landing_product_handle = 'sub90-wall-ball-target'
  assign landing_product = all_products[landing_product_handle]
  if landing_product == blank
    for product_item in collections.all.products
      if product_item.title == 'SUB90 Wall Ball Target'
        assign landing_product = product_item
        break
      endif
    endfor
  endif
  if landing_product == blank
    for product_item in collections.all.products
      if product_item.title contains 'SUB90 Wall Ball Target'
        assign landing_product = product_item
        break
      endif
    endfor
  endif

  assign fallback_variant_id = '45731971465299'
  assign fallback_product_id = '8004163469395'
  assign variant_black_white = fallback_variant_id
  assign variant_black_orange = fallback_variant_id
  assign variant_white_black = fallback_variant_id
  assign variant_white_blue = fallback_variant_id

  if landing_product
    assign fallback_variant_id = landing_product.selected_or_first_available_variant.id
    assign fallback_product_id = landing_product.id
    assign variant_black_white = fallback_variant_id
    assign variant_black_orange = fallback_variant_id
    assign variant_white_black = fallback_variant_id
    assign variant_white_blue = fallback_variant_id
    for variant in landing_product.variants
      case variant.title
        when 'Black / White'
          assign variant_black_white = variant.id
        when 'Black / Orange'
          assign variant_black_orange = variant.id
        when 'White / Black'
          assign variant_white_black = variant.id
        when 'White / Blue'
          assign variant_white_blue = variant.id
      endcase
    endfor
  endif
-%}
