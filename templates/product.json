type":"image-with-text","blocks":{"heading_xKNnm8":{"type":"heading","settings":{"heading":"Image with text","heading_size":"h1"}},"text_hxPXbh":{"type":"text","settings":{"text":"<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.<\/p>","text_style":"body"}}},"block_order":["heading_xKNnm8","text_hxPXbh"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/IMG_2507front.webp","height":"adapt","desktop_image_width":"medium","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","color_scheme":"","padding_top":28,"padding_bottom":36}},"rich_text_zynihK":{"type":"rich-text","blocks":{"heading_MremeM":{"type":"heading","settings":{"heading":"You don't lose Hyrox on the run.You lose it on no-reps.","heading_size":"h0"}},"text_Trzg3i":{"type":"text","settings":{"text":"<h5>Train against a taped square or a rack-mounted target at the wrong height and your depth and aim drift. Then race day comes, the judge's standard doesn't move, and every missed rep is wasted seconds you'll never claw back.<\/h5>"}},"text_eR6VDn":{"type":"text","settings":{"text":"<p><strong>The SUB90 Wall Ball Target fixes the root cause. It bolts to any wall at true competition height, sits proud of the surface for real tactile feedback, and is sized to the standard, so the rep you drill at home is the rep that counts on the floor.<\/strong><\/p>"}},"button_ADcB7h":{"type":"button","settings":{"button_label":"TRAIN AT THE STANDARD.$39.99","button_link":"","button_style_secondary":false,"button_label_2":"","button_link_2":"","button_style_secondary_2":false}}},"block_order":["heading_MremeM","text_Trzg3i","text_eR6VDn","button_ADcB7h"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":40,"padding_bottom":52}},"multirow_xBwPGJ":{"type":"multirow","blocks":{"row_jrmwzE":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Sub.webp","caption":"Mount it once","heading":"Any wall becomes your station","text":"<h5>Studs, wood, concrete, or brick, indoor or outdoor. Set it at competition height regardless of your ceiling clearance and free up the space your rack was hogging.<\/h5><p>Tip: mounting on drywall without studs isn't recommended. These targets take a beating.<\/p>","button_label":"","button_link":""}},"row_px8Lc9":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/SUB_90_row_2.webp","caption":"Built to be abused","heading":"Ultra-strong PETG construction","text":"<p>Engineered to withstand intense sessions and harsh weather alike. Hit it as hard as you want. It shrugs off the impact and the elements, so you replace it never, not every season.<\/p>","button_label":"","button_link":""}},"row_abQBVB":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/SUB_90_row_3.webp","caption":"Feel every rep","heading":"Tactile feedback, not guesswork","text":"<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.<\/p>","button_label":"","button_link":""}}},"block_order":["row_jrmwzE","row_px8Lc9","row_abQBVB"],"name":"t:sections.multirow.presets.name","settings":{"image_height":"adapt","desktop_image_width":"medium","image_layout":"alternate-left","heading_size":"h1","text_style":"body","button_style":"secondary","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","row_color_scheme":"","padding_top":28,"padding_bottom":20}},"rich_text_q7yyLi":{"type":"rich-text","blocks":{"heading_abYkbn":{"type":"heading","settings":{"heading":"Squat low. Aim high.","heading_size":"h0"}},"text_c4MJkB":{"type":"text","settings":{"text":"<p>Every rep should have purpose. Set the standard on your own wall and walk into race day with no doubt.<\/p>"}},"button_Yrw97t":{"type":"button","settings":{"button_label":"ADD TO CART.$34.99","button_link":"","button_style_secondary":false,"button_label_2":"","button_link_2":"","button_style_secondary_2":false}},"text_cpHUaH":{"type":"text","settings":{"text":"<p>Free US shipping. 30-day returns. Built by athletes in the USA.<\/p>"}}},"block_order":["heading_abYkbn","text_c4MJkB","button_Yrw97t","text_cpHUaH"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"scheme-1","full_width":true,"padding_top":40,"padding_bottom":52}},"rich_text_Awk36F":{"type":"rich-text","blocks":{"caption_nVWcyz":{"type":"caption","settings":{"caption":"Build the whole station","text_style":"caption-with-letter-spacing","text_size":"medium"}},"heading_3g398j":{"type":"heading","settings":{"heading":"The target is the start. Here's the rest.","heading_size":"h1"}},"text_M49dnf":{"type":"text","settings":{"text":"<p>Somewhere to store the ball, grips for your hands, a way to mark the height. Grab it in one cart and save versus buying it piece by piece.<\/p>"}}},"block_order":["caption_nVWcyz","heading_3g398j","text_M49dnf"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":32,"padding_bottom":28}},"multicolumn_XYkbqw":{"type":"multicolumn","blocks":{"column_wtHFfR":{"type":"column","settings":{"title":"HYROX Home Kit","text":"<p>Target + speed jump rope + palm grips. The full race-prep package for one athlete.<\/p>","link_label":"$74.99$89","link":""}},"column_y6NhCt":{"type":"column","settings":{"title":"Complete Setup","text":"<p>Target + storage rack + floor tiles (4-pack) + chalk. Everything to turn a bare wall into a finished station.<\/p>","link_label":"$99.99$120","link":""}}},"block_order":["column_wtHFfR","column_y6NhCt"],"name":"t:sections.multicolumn.presets.name","settings":{"title":"","heading_size":"h1","image_width":"full","image_ratio":"square","button_label":"","button_link":"","columns_desktop":2,"column_alignment":"center","background_style":"primary","color_scheme":"","columns_mobile":"1","swipe_on_mobile":false,"padding_top":0,"padding_bottom":0}},"rich_text_NWawDE":{"type":"rich-text","blocks":{"text_ENfFNJ":{"type":"text","settings":{"text":"<p>Training as a pair, or both heights?<a href=\"https:\/\/sub90fitness.com\/products\/brick-haus-wall-ball-target-2-pack\">Grab the 2-pack<\/a>and add the height marking kit in the buy box.<\/p>"}}},"block_order":["text_ENfFNJ"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":12,"padding_bottom":32}},"image_with_text_RXxHcV":{"type":"image-with-text","blocks":{"heading_xiYRkw":{"type":"heading","settings":{"heading":"The \"you chickened out\" guarantee","heading_size":"h1"}},"text_F7978Y":{"type":"text","settings":{"text":"<p>Train on it for a full 30 days. If it isn't the most solid target you've hit, or anything is wrong with your order, email us and we'll make it right. Real humans, real promise.<\/p>","text_style":"body"}}},"block_order":["heading_xiYRkw","text_F7978Y"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/3day.jpg","height":"small","desktop_image_width":"small","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","color_scheme":"","padding_top":36,"padding_bottom":36}},"image_with_text_xQeYgi":{"type":"image-with-text","blocks":{"heading_Kamm46":{"type":"heading","settings":{"heading":"<strong>We build these by hand, and we actually use them.<\/strong>","heading_size":"h1"}},"text_GyNrGi":{"type":"text","settings":{"text":"<p>\"We have a lot of fun making these targets, and we love helping people get active. Every target is designed, tested, and shipped by our small crew in Frisco, Texas, because we train on these same walls. If anything is ever wrong with your order, email me and we'll make it right. That's a promise from a human, not a help desk.\"<\/p>","text_style":"body"}}},"block_order":["heading_Kamm46","text_GyNrGi"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/IMG_2464.webp","height":"adapt","desktop_image_width":"small","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","color_scheme":"","padding_top":36,"padding_bottom":36}},"collage_CJCUxh":{"type":"collage","blocks":{"image_VTzRJE":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/sub_mini3.webp"}},"product_jr4KTc":{"type":"product","settings":{"product":"sub-90-wall-ball-target","second_image":true}},"product_QAfMeY":{"type":"product","settings":{"product":"sub-90-wall-ball-target","second_image":true}}},"block_order":["image_VTzRJE","product_jr4KTc","product_QAfMeY"],"name":"t:sections.collage.presets.name","settings":{"heading":"Multimedia collage","heading_size":"h0","desktop_layout":"right","mobile_layout":"collage","card_styles":"product-card-wrapper","color_scheme":"","padding_top":36,"padding_bottom":36}},"video_wkzQiH":{"type":"video","name":"t:sections.video.presets.name","settings":{"heading":"<strong>90 seconds from box to first rep<\/strong>","heading_size":"h1","enable_video_looping":true,"video_url":"https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc","cover_image":"shopify:\/\/shop_images\/sub_mini2.webp","description":"","full_width":false,"color_scheme":"","padding_top":0,"padding_bottom":32}},"multicolumn_XtQJY4":{"type":"multicolumn","blocks":{"column_HcFCrG":{"type":"column","settings":{"title":"Column","text":"<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.<\/p>","link_label":"","link":""}},"column_HREHY6":{"type":"column","settings":{"title":"Column","text":"<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.<\/p>","link_label":"","link":""}},"column_iPB6xb":{"type":"column","settings":{"title":"Column","text":"<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.<\/p>","link_label":"","link":""}},"column_8C3kNX":{"type":"column","settings":{"title":"Column","text":"<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.<\/p>","link_label":"","link":""}}},"block_order":["column_HcFCrG","column_HREHY6","column_iPB6xb","column_8C3kNX"],"name":"t:sections.multicolumn.presets.name","settings":{"title":"Multicolumn","heading_size":"h1","image_width":"full","image_ratio":"adapt","button_label":"Button label","button_link":"","columns_desktop":2,"column_alignment":"left","background_style":"primary","color_scheme":"","columns_mobile":"1","swipe_on_mobile":false,"padding_top":36,"padding_bottom":36}},"collapsible_content_feqULm":{"type":"collapsible-content","blocks":{"collapsible_row_VT8BQw":{"type":"collapsible_row","settings":{"heading":"Can I mount it on drywall?","icon":"check_mark","row_content":"<p>It mounts to studs, wood, concrete, or brick, indoor or outdoor. Mounting on drywall without studs isn't recommended, because these targets are built to take heavy impact and need a solid anchor.<\/p>","page":""}},"collapsible_row_FtfhJx":{"type":"collapsible_row","settings":{"heading":"Will it survive outdoors?","icon":"check_mark","row_content":"<p>Yes. It's made from ultra-strong PETG that resists both intense training and harsh weather, with no rust or corrosion, indoors or out.<\/p>","page":""}},"collapsible_row_y6fTHr":{"type":"collapsible_row","settings":{"heading":"Is it true competition height?","icon":"check_mark","row_content":"<p>Because it's wall-mounted, you set it at competition height regardless of your ceiling clearance. It's also sized slightly smaller than the competition plate so your training reps build race-day precision.<\/p>","page":""}},"collapsible_row_qTkyGx":{"type":"collapsible_row","settings":{"heading":"How fast does it ship?","icon":"check_mark","row_content":"<p>Free US ground shipping on every order, shipped from Frisco, TX. Order before the daily cutoff and it ships the same business day (Mon to Fri, 9 to 5 CST).<\/p>","page":""}},"collapsible_row_4fhHeJ":{"type":"collapsible_row","settings":{"heading":"What if it's not for me?","icon":"check_mark","row_content":"<p>You're covered by our 30-day \"you chickened out\" return policy. If anything is wrong with your order, we'll gladly make it right.<\/p>","page":""}}},"block_order":["collapsible_row_VT8BQw","collapsible_row_FtfhJx","collapsible_row_y6fTHr","collapsible_row_qTkyGx","collapsible_row_4fhHeJ"],"name":"t:sections.collapsible_content.presets.name","settings":{"caption":"","heading":"Why athletes ditch the alternatives","heading_size":"h1","heading_alignment":"center","layout":"none","container_color_scheme":"","color_scheme":"","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":36,"padding_bottom":36}}},"order":["main","disclosures","rich_text_FGAznR","multicolumn_4Cdbwc","related-products","image_with_text_LmGHDQ","rich_text_zynihK","multirow_xBwPGJ","rich_text_q7yyLi","rich_text_Awk36F","multicolumn_XYkbqw","rich_text_NWawDE","image_with_text_RXxHcV","image_with_text_xQeYgi","collage_CJCUxh","v